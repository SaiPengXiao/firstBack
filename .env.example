# 复制为 .env：cp .env.example .env（.env 不会提交到 Git）

# --- MySQL（任选一种方式）---

# 方式 A：Railway 面板复制的 Connection URL（推荐，本地公网连 Railway）
# MYSQL_URL=mysql://root:密码@主机.proxy.rlwy.net:端口/库名

# 方式 B：分项（也支持 Railway 内网变量名 MYSQLHOST / MYSQLUSER 等）
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=railway

# 方式 C：Go 驱动 DSN（高级）
# MYSQL_DSN=user:pass@tcp(host:port)/db?parseTime=true&loc=UTC&charset=utf8mb4&multiStatements=true&tls=true

# 公网远程主机默认加密 tls=skip-verify（Railway 自签证书）；本地 127.0.0.1 不加。可强制：MYSQL_TLS=true

# 本地开发
# PORT=8080
# CORS_ALLOW_ORIGIN=http://localhost:5173

# Railway 生产（在 firstBack 服务 Variables 里设置，不要写进 Git）
# GIN_MODE=release
# JWT_SECRET=一串足够长的随机字符串
# CORS_ALLOW_ORIGIN=https://你的前端域名