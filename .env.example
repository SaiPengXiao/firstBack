# 复制本文件为 .env 并改成你的真实信息（.env 不会提交到 Git）
# 在 firstBack 目录下执行: cp .env.example .env

MYSQL_USER=root
MYSQL_PASSWORD=111111
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=firstback

# 本地开发可选
# PORT=8080
# CORS_ALLOW_ORIGIN=http://localhost:5173

# 生产环境建议设置
# GIN_MODE=release
# JWT_SECRET=一串足够长的随机字符串